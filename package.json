{
  "name": "ai-usage-inspector",
  "version": "2.0.0",
  "description": "Zero-dependency hook that records every AI coding-agent prompt (tokens, model, mode, cost, context %) from Claude Code and OpenAI Codex, and shows it in a local dashboard.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "ai-usage-inspector": "install.mjs"
  },
  "scripts": {
    "install-hook": "node install.mjs",
    "install-claude": "node install.mjs --claude",
    "install-codex": "node install.mjs --codex",
    "install-local": "node install.mjs --local",
    "uninstall": "node install.mjs --uninstall",
    "view": "node viewer/server.mjs"
  },
  "keywords": [
    "claude",
    "claude-code",
    "openai",
    "codex",
    "hook",
    "usage",
    "tokens",
    "cost",
    "dashboard",
    "observability"
  ],
  "dependencies": {}
}
